<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CourseList.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- 列表卡片：实色填充（Fluent CardBackgroundFillColorDefaultBrush 在部分主题为半透明） -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CourseListCardBackgroundBrush" Color="White" />
                    <SolidColorBrush x:Key="CourseListCardStrokeBrush" Color="#D0D0D0" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CourseListCardBackgroundBrush" Color="#FF2C2C2C" />
                    <SolidColorBrush x:Key="CourseListCardStrokeBrush" Color="#FF484848" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
