<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CourseList.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList"
    xmlns:views="using:CourseList.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CourseList">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 原生 TitleBar 控件内置侧栏键（PaneToggleRequested），与系统标题栏同一套输入路径；高度在代码中设为 Standard -->
        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Title="📘 我的课程管理系统"
                  IsPaneToggleButtonVisible="True"
                  PaneToggleRequested="AppTitleBar_PaneToggleRequested" />

        <Frame x:Name="RootFrame"
               Grid.Row="1"
               SourcePageType="views:MainPage" />
    </Grid>
</Window>
