<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CourseList.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList"
    xmlns:views="using:CourseList.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CourseList">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 自定义标题栏（必须放在外层行中，保证拖动/非客户区命中行为正常） -->
        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Title="📘 我的课程管理系统"
                  FontWeight="Bold"/>

        <!-- 小窗模式：用于打开/关闭侧边栏覆盖层 -->
        <Button x:Name="CompactNavButton"
                Grid.Row="0"
                Content="≡"
                Width="32"
                Height="32"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,120,0"
                Visibility="Collapsed"
                Click="CompactNavButton_Click" />

        <!-- 应用内容位于第二行 -->
        <Frame x:Name="RootFrame"
               Grid.Row="1"
               SourcePageType="views:MainPage" />
        

    </Grid>
</Window>
