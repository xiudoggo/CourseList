<ContentDialog
    x:Class="CourseList.Views.CourseFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="12"
    Title="新增课程"
    PrimaryButtonText="保存"
    CloseButtonText="取消">
    <ScrollViewer>
    <StackPanel Spacing="16" Padding="20">
        <TextBox x:Name="NameBox" Header="课程名称"/>
        <TextBox x:Name="TeacherBox" Header="教师"/>
        <TextBox x:Name="ClassroomBox" Header="教室"/>

        <ComboBox x:Name="DayCombo" Header="星期" SelectedIndex="0">
            <ComboBoxItem Content="星期一" Tag="Monday"/>
            <ComboBoxItem Content="星期二" Tag="Tuesday"/>
            <ComboBoxItem Content="星期三" Tag="Wednesday"/>
            <ComboBoxItem Content="星期四" Tag="Thursday"/>
            <ComboBoxItem Content="星期五" Tag="Friday"/>
            <ComboBoxItem Content="星期六" Tag="Saturday"/>
            <ComboBoxItem Content="星期日" Tag="Sunday"/>
        </ComboBox>

        <TextBox x:Name="PeriodsBox" Header="节次（1,2,3 逗号分隔）"/>

        <TextBlock Text="课程颜色"/>

        <ColorPicker x:Name="CourseColorPicker"
                     IsAlphaEnabled="False"
                     IsMoreButtonVisible="True"
                     ColorChanged="CourseColorPicker_ColorChanged"/>
        <!-- <Border Height="30" -->
        <!--         CornerRadius="6" -->
        <!--         Margin="0,5,0,0"> -->
        <!--     <Border.Background> -->
        <!--         <SolidColorBrush x:Name="PreviewBrush"/> -->
        <!--     </Border.Background> -->
        <!-- </Border> -->
        <ComboBox x:Name="WeekTypeCombo" Header="周类型" SelectedIndex="0">
            <ComboBoxItem Content="全周" Tag="0"/>
            <ComboBoxItem Content="单周" Tag="1"/>
            <ComboBoxItem Content="双周" Tag="2"/>
        </ComboBox>

        <TextBox x:Name="NoteBox" Header="备注"/>
    </StackPanel>
        </ScrollViewer>
</ContentDialog>