<Page
    x:Class="CourseList.Views.CourseListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:models="using:CourseList.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:media="using:Microsoft.UI.Xaml.Media">

    <Page.Resources>
        <!-- 课程卡片模板（固定宽高 + 内部滚动） -->
        <DataTemplate x:Key="CourseCardTemplate" x:DataType="models:Course">
            <!-- 外层留白：hover 缩放时边框不被布局裁切 -->
            <Grid Margin="6">
            <Border x:Name="RootBorder"
                    Background="{ThemeResource CourseListCardBackgroundBrush}"
                    BorderBrush="{ThemeResource CourseListCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0"
                    Margin="0"
                    Width="Auto"
                    MaxWidth="260"
                    HorizontalAlignment="Stretch"
                    Height="170"
                    Tag="{x:Bind}"
                    Translation="0,0,12"
                    RenderTransformOrigin="0.5,0.5"
                    PointerPressed="CourseCard_PointerPressed"
                    PointerEntered="CourseCard_PointerEntered"
                    PointerExited="CourseCard_PointerExited">
                <Border.Shadow>
                    <media:ThemeShadow />
                </Border.Shadow>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <!-- 卡片内部内容允许滚动，避免撑高卡片导致重叠 -->
                <ScrollViewer Padding="12"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 课程名称 -->
                        <TextBlock Grid.Row="0" 
                               Text="{x:Bind NameWrapped}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                        <!-- 教师 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="👨‍🏫 " FontSize="14"/>
                        <TextBlock Text="{x:Bind TeacherWrapped}" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- 教室和时间 -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="📍 " FontSize="14"/>
                        <TextBlock Text="{x:Bind ClassroomWrapped}" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="🕐 " FontSize="14"/>
                        <TextBlock Text="{x:Bind ScheduleDisplayWrapped}" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- 备注 -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="📝 " FontSize="14"/>
                        <TextBlock Text="{x:Bind NoteWrapped}" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
            </Grid>
        </DataTemplate>

        <!-- 小窗 compact：横向长条列表卡片（不显示筛选/操作按钮，仅展示列表） -->
        <DataTemplate x:Key="CourseCardCompactTemplate" x:DataType="models:Course">
            <Grid Margin="6">
            <Border x:Name="CompactRootBorder"
                    Background="{ThemeResource CourseListCardBackgroundBrush}"
                    BorderBrush="{ThemeResource CourseListCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12,10"
                    Margin="0"
                    Tag="{x:Bind}"
                    HorizontalAlignment="Stretch"
                    Height="92"
                    Translation="0,0,10"
                    RenderTransformOrigin="0.5,0.5"
                    PointerPressed="CourseCard_PointerPressed"
                    PointerEntered="CourseCard_PointerEntered"
                    PointerExited="CourseCard_PointerExited">
                <Border.Shadow>
                    <media:ThemeShadow />
                </Border.Shadow>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid ColumnDefinitions="6,*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Width="6"
                            CornerRadius="3">
                        <Border.Background>
                            <SolidColorBrush Color="{x:Bind UiColor}" />
                        </Border.Background>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Spacing="6">
                        <TextBlock Text="{x:Bind NameWrapped}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{x:Bind TeacherWrapped}"
                                   FontSize="13"
                                   TextWrapping="NoWrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ClassroomWrapped}"
                                   FontSize="13"
                                   TextWrapping="NoWrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ScheduleDisplayWrapped}"
                                   FontSize="13"
                                   TextWrapping="NoWrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="CourseListRootGrid" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="📚 课程列表"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button x:Name="AddBtn"
                    Grid.Row="0"
                    Grid.Column="1"
                    Content="➕ 新增"
                    Margin="8,0,0,0"
                    Click="AddBtn_Click"/>
            <Button x:Name="EditBtn"
                    Grid.Row="0"
                    Grid.Column="2"
                    Content="✏️ 编辑"
                    Margin="8,0,0,0"
                    Click="EditBtn_Click"/>
            <Button x:Name="DeleteBtn"
                    Grid.Row="0"
                    Grid.Column="3"
                    Content="🗑️ 删除"
                    Margin="8,0,0,0"
                    Click="DeleteBtn_Click">
                <FlyoutBase.AttachedFlyout>
                    <Flyout x:Name="DeleteConfirmFlyout" Placement="Top">
                        <StackPanel Spacing="10" MinWidth="240">
                            <TextBlock x:Name="DeleteConfirmText"
                                       Text="确定要删除该课程吗？"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="取消" Click="DeleteConfirmCancel_Click"/>
                                <Button Content="删除"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Click="DeleteConfirmOk_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
            </Button>

            <!-- 搜索 / 筛选 -->
            <StackPanel x:Name="FiltersStackPanel" Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                <TextBox x:Name="SearchBox"
                         Width="260"
                         PlaceholderText="搜索：名称/教师/教室/备注"
                         TextChanged="SearchBox_TextChanged"/>

                <ComboBox x:Name="DayFilterCombo"
                          Width="140"
                          Header="星期"
                          SelectedIndex="0"
                          SelectionChanged="FilterCombo_SelectionChanged">
                    <ComboBoxItem Content="全部" Tag="All"/>
                    <ComboBoxItem Content="周一" Tag="Monday"/>
                    <ComboBoxItem Content="周二" Tag="Tuesday"/>
                    <ComboBoxItem Content="周三" Tag="Wednesday"/>
                    <ComboBoxItem Content="周四" Tag="Thursday"/>
                    <ComboBoxItem Content="周五" Tag="Friday"/>
                    <ComboBoxItem Content="周六" Tag="Saturday"/>
                    <ComboBoxItem Content="周日" Tag="Sunday"/>
                </ComboBox>

                <ComboBox x:Name="WeekTypeFilterCombo"
                          Width="150"
                          Header="周类型"
                          SelectedIndex="0"
                          SelectionChanged="FilterCombo_SelectionChanged">
                    <ComboBoxItem Content="全部" Tag="All"/>
                    <ComboBoxItem Content="全周" Tag="0"/>
                    <ComboBoxItem Content="单周" Tag="1"/>
                    <ComboBoxItem Content="双周" Tag="2"/>
                </ComboBox>

                <ComboBox x:Name="PeriodFilterCombo"
                          Width="140"
                          Header="包含节次"
                          SelectedIndex="0"
                          SelectionChanged="FilterCombo_SelectionChanged">
                    <ComboBoxItem Content="全部" Tag="All"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- 课程列表：必须包在 ScrollViewer 内，否则超出可视区域会被裁剪且无滚动条 -->
        <!-- 仅纵向滚动：横向不滚动，UniformGridLayout 在可视宽度内自动换行 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch">
            <muxc:ItemsRepeater x:Name="CourseRepeater"
                                HorizontalAlignment="Stretch"
                                ItemTemplate="{StaticResource CourseCardTemplate}">
                <muxc:ItemsRepeater.Layout>
                    <muxc:UniformGridLayout MinItemWidth="220"
                                            MinItemHeight="182"
                                            MinRowSpacing="12"
                                            MinColumnSpacing="12"
                                            ItemsStretch="Fill" />
                </muxc:ItemsRepeater.Layout>
            </muxc:ItemsRepeater>
        </ScrollViewer>

        <!-- 空状态提示 -->
        <TextBlock x:Name="EmptyText" 
                   Grid.Row="1"
                   Text="还没有课程，点击右上角添加课程～" 
                   FontSize="16"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <TeachingTip x:Name="CourseListSelectionTeachingTip"
                     Title="提示"
                     PreferredPlacement="Bottom"
                     IsLightDismissEnabled="True"/>
    </Grid>
</Page>
