<Page
    x:Class="CourseList.Views.CourseListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:models="using:CourseList.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <!-- 课程卡片模板 -->
        <DataTemplate x:Key="CourseCardTemplate" x:DataType="models:Course">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="8"
                    Width="280">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 课程名称 -->
                    <TextBlock Grid.Row="0" 
                               Text="{x:Bind Name}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                    <!-- 教师 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="👨‍🏫 " FontSize="14"/>
                        <TextBlock Text="{x:Bind Teacher}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- 教室和时间 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="📍 " FontSize="14"/>
                        <TextBlock Text="{x:Bind Classroom}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="🕐 " FontSize="14"/>
                        <TextBlock Text="{x:Bind ScheduleDisplay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="📚 课程列表" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:Name="AddBtn" Content="➕ 新增课程" Click="AddBtn_Click" Style="{ThemeResource AccentButtonStyle}"/>
                <Button x:Name="EditBtn" Content="✏️ 编辑课程" Click="EditBtn_Click"/>
                <Button x:Name="DeleteBtn" Content="🗑️ 删除课程" Click="DeleteBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- 课程列表 -->
        <muxc:ItemsRepeater Grid.Row="1" 
                            x:Name="CourseRepeater"
                            ItemTemplate="{StaticResource CourseCardTemplate}">
            <muxc:ItemsRepeater.Layout>
                <muxc:UniformGridLayout MinItemWidth="280" MinItemHeight="150"/>
            </muxc:ItemsRepeater.Layout>
        </muxc:ItemsRepeater>

        <!-- 空状态提示 -->
        <TextBlock x:Name="EmptyText" 
                   Grid.Row="1"
                   Text="还没有课程，点击右上角添加课程～" 
                   FontSize="16"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Page>
