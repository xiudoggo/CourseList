<Page
    x:Class="CourseList.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views">

    <ScrollViewer>
        <StackPanel Spacing="20" Padding="20">

            <TextBlock Text="👋 欢迎回来"
                       FontSize="28"
                       FontWeight="Bold"/>

            <TextBlock x:Name="TodayWeekdayText"
                       Text="今天是星期一"
                       FontSize="28"/>

            <TextBlock x:Name="TodayCourseSummaryText"
                       Text="今天很轻松"
                       FontSize="18"
                       Opacity="0.9"/>

            

        </StackPanel>
    </ScrollViewer>
</Page>