<Page
    x:Class="CourseList.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <DataTemplate x:Key="TodayCourseCardTemplate" x:DataType="local:TodayCourseCardItem">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    HorizontalAlignment="Left"
                    Width="320"
                    Height="124">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,8,0,8"
                            CornerRadius="3"
                            Background="{x:Bind ColorBrush}"/>

                    <Grid Grid.Column="1" Margin="12,10,12,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                               Text="{x:Bind Name}"
                               FontSize="16"
                               FontWeight="Bold"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind Teacher}"
                                   Margin="0,5,0,0"
                                   FontSize="14"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Row="2"
                                   Text="{x:Bind Classroom}"
                                   Margin="0,3,0,0"
                                   FontSize="14"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Row="3"
                                   Text="{x:Bind TimeText}"
                                   Margin="0,5,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="20" ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" MinWidth="230" Spacing="16" VerticalAlignment="Top">
                <TextBlock Text="👋 欢迎回来"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock x:Name="TodayWeekdayText"
                           Text="今天是星期一"
                           FontSize="28"/>

                <TextBlock x:Name="TodayCourseSummaryText"
                           Text="今天很轻松"
                           FontSize="18"
                           Opacity="0.9"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Spacing="10"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        MaxWidth="340">
                <TextBlock x:Name="TodayCourseTitleText"
                           Text="今日课程"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <muxc:ItemsRepeater x:Name="TodayCourseRepeater"
                                    ItemTemplate="{StaticResource TodayCourseCardTemplate}">
                    <muxc:ItemsRepeater.Layout>
                        <muxc:StackLayout Orientation="Vertical"
                                          Spacing="8"/>
                    </muxc:ItemsRepeater.Layout>
                </muxc:ItemsRepeater>

                <TextBlock x:Name="TodayEmptyText"
                           Text="今天没有课程安排"
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>