<Page
    x:Class="CourseList.Views.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:models="using:CourseList.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <!-- 课程单元格样式 -->
        <Style x:Key="CourseCellStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 课程表 Grid -->
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ScheduleGrid" Margin="10">
                <!-- 列定义 -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 行定义：标题行 + 11节 -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- 星期标题 -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="节次" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期一" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期二" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期三" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期四" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="5" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期五" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期六" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="7" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="星期日" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- 节次编号 -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="8" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="8" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="9" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="9" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="10" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="11" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <TextBlock Text="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>

                <!-- 课程单元格将通过代码生成 -->
            </Grid>
        </ScrollViewer>

        <!-- 右下角悬浮操作栏 -->
        <Grid Grid.Row="1" 
              HorizontalAlignment="Right" 
              VerticalAlignment="Bottom" 
              Margin="0,0,20,20">
            
            <!-- 展开的操作按钮横条 -->
            <Border x:Name="ExpandedPanel" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="10,6"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0"/>
                </Border.RenderTransform>
                
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="AddCourseBtn" Content="➕ 新增" Click="AddCourseBtn_Click" Style="{ThemeResource AccentButtonStyle}"/>
                    <Button x:Name="EditCourseBtn" Content="✏️ 编辑" Click="EditCourseBtn_Click"/>
                    <Button x:Name="DeleteCourseBtn" Content="🗑️ 删除" Click="DeleteCourseBtn_Click"/>
                </StackPanel>
            </Border>
            
            <!-- 悬浮触发按钮（左箭头） -->
            <Button x:Name="ToggleFloatBtn" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="40"
                    Height="40"
                    Padding="0"
                    CornerRadius="20"
                    Background="{ThemeResource SystemAccentColor}"
                    Foreground="White"
                    BorderThickness="2"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    Click="ToggleFloatBtn_Click"
                    ToolTipService.ToolTip="操作菜单">
                <Button.Content>
                    <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Page>
