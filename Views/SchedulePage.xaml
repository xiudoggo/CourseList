<Page
    x:Class="CourseList.Views.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:models="using:CourseList.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- 浅色模式：背景极淡蓝，标题/首列略深 -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="ScheduleBackgroundColor">#F5F8FF</Color>
                    <Color x:Key="ScheduleHeaderColor">#E2EBFF</Color>
                    <Color x:Key="ScheduleHeaderTextColor">#222222</Color>
                </ResourceDictionary>
                <!-- 深色模式：背景中灰，标题/首列淡灰 -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="ScheduleBackgroundColor">#303030</Color>
                    <Color x:Key="ScheduleHeaderColor">#3A3A3A</Color>
                    <Color x:Key="ScheduleHeaderTextColor">#F2F2F2</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="ScheduleBackgroundBrush"
                             Color="{ThemeResource ScheduleBackgroundColor}" />
            <SolidColorBrush x:Key="ScheduleHeaderBrush"
                             Color="{ThemeResource ScheduleHeaderColor}" />
            <SolidColorBrush x:Key="ScheduleHeaderTextBrush"
                             Color="{ThemeResource ScheduleHeaderTextColor}" />

            <!-- 课程单元格样式：去掉网格线 -->
            <Style x:Key="CourseCellStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 课程表 Grid：外层包一层圆角背景 -->
        <Border Grid.Row="0"
                Margin="10"
                CornerRadius="16"
                Background="{ThemeResource ScheduleBackgroundBrush}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="ScheduleGrid"
                      Margin="8"
                      Background="Transparent"
                      PointerPressed="ScheduleGrid_PointerPressed">
                <!-- 列定义 -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 行定义：由代码根据 PeriodCount 动态生成 -->

                <!-- 星期标题：颜色与背景同色系，适配深浅色 -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="节次/星期" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期一" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期二" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期三" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期四" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="5" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期五" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期六" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="7" Style="{StaticResource CourseCellStyle}" Background="{ThemeResource ScheduleHeaderBrush}">
                    <TextBlock Text="星期日" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource ScheduleHeaderTextBrush}"/>
                </Border>

                <!-- 节次标题与课程单元格将通过代码生成 -->
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 右下角悬浮操作栏（相对定位：锚定右下角，内部两列布局） -->
        <Grid Grid.Row="1"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 展开的操作按钮横条 -->
            <Border x:Name="ExpandedPanel"
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="10,6"
                    RenderTransformOrigin="1,0.5"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0"/>
                </Border.RenderTransform>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="AddCourseBtn" Content="➕ 新增" Click="AddCourseBtn_Click" Style="{ThemeResource AccentButtonStyle}"/>
                    <Button x:Name="EditCourseBtn" Content="✏️ 编辑" Click="EditCourseBtn_Click"/>
                    <Button x:Name="DeleteCourseBtn" Content="🗑️ 删除" Click="DeleteCourseBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- 悬浮触发按钮：相对定位在横条右侧 -->
            <Button x:Name="ToggleFloatBtn"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Width="40"
                    Height="40"
                    Padding="0"
                    CornerRadius="4"
                    Background="{ThemeResource SystemAccentColor}"
                    Foreground="White"
                    BorderThickness="2"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    Click="ToggleFloatBtn_Click">
                <Button.Content>
                    <FontIcon x:Name="ToggleIcon"
                              Glyph="&#xE76B;"
                              FontSize="16"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform x:Name="ToggleIconRotate" Angle="0"/>
                        </FontIcon.RenderTransform>
                    </FontIcon>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Page>
