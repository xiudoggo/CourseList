<Page
    x:Class="CourseList.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Page.Resources>
        <Style x:Key="SettingsTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
        </Style>
        <Style x:Key="SettingsSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
        </Style>
    </Page.Resources>
    

    <Border Margin="20" CornerRadius="16" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="20">
        <!-- 外层滚动：当页面高度不足时，出现滚动条，避免按钮被挤出窗口 -->
        <ScrollViewer x:Name="SettingsScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左列：系统设置 -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                    <TextBlock Text="系统设置" Style="{StaticResource SettingsTitleStyle}"/>

                    <TextBlock Text="主题设置" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <ComboBox x:Name="ThemeComboBox"
                              SelectionChanged="ThemeChanged"
                              Width="220">
                        <ComboBoxItem Content="跟随系统" Tag="Default" />
                        <ComboBoxItem Content="浅色" Tag="Light"/>
                        <ComboBoxItem Content="深色" Tag="Dark"/>
                    </ComboBox>

                    <TextBlock Text="关闭行为" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <StackPanel Spacing="6">
                        <RadioButton x:Name="MinimizeToTrayRadio"
                                     Content="最小化到系统托盘"
                                     Checked="MinimizeToTrayRadio_Checked"/>
                        <RadioButton x:Name="DirectCloseRadio"
                                     Content="直接关闭"
                                     Checked="DirectCloseRadio_Checked"/>
                    </StackPanel>

                    <CheckBox x:Name="ClosePromptCheckBox"
                              Content="关闭时提示"
                              Checked="ClosePromptCheckBox_Changed"
                              Unchecked="ClosePromptCheckBox_Changed"
                              Margin="0,10,0,0"/>

                    <TextBlock Text="课表方案" Style="{StaticResource SettingsTitleStyle}" Margin="0,24,0,0"/>
                    <TextBlock Text="当前方案" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <ComboBox x:Name="SchemeComboBox"
                              SelectionChanged="SchemeComboBox_SelectionChanged"
                              Width="220"
                              DisplayMemberPath="Name"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="AddSchemeBtn" Content="新建方案" Click="AddSchemeBtn_Click"/>
                        <Button x:Name="RenameSchemeBtn" Content="重命名" Click="RenameSchemeBtn_Click"/>
                        <Button x:Name="DeleteSchemeBtn" Content="删除" Click="DeleteSchemeBtn_Click"/>
                    </StackPanel>

                    <TextBlock Text="教务系统导入" Style="{StaticResource SettingsSectionLabelStyle}" Margin="0,16,0,8"/>
                    <Button x:Name="OpenImportButton"
                            Content="打开教务系统"
                            Width="220"
                            Click="OpenImportButton_Click"/>
                </StackPanel>

                <!-- 右列：课程表功能设置 -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Left">
                    <TextBlock Text="课程表功能设置" Style="{StaticResource SettingsTitleStyle}"/>

                    <TextBlock Text="设置学期起始周日期" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <DatePicker x:Name="SemesterStartDatePicker"
                                DateChanged="SemesterStartDatePicker_DateChanged"
                                HorizontalAlignment="Left"/>

                    <TextBlock Text="学期总周数" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <NumberBox x:Name="SemesterTotalWeeksBox"
                                Minimum="1"
                                Maximum="30"
                                ValueChanged="SemesterTotalWeeksBox_ValueChanged"
                                Width="120"
                                HorizontalAlignment="Left"/>

                    <TextBlock Text="课程表显示范围" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <ComboBox x:Name="WeekRangeComboBox"
                              SelectionChanged="WeekRangeChanged"
                              Width="120">
                        <ComboBoxItem Content="周一到周五" Tag="5"/>
                        <ComboBoxItem Content="周一到周日" Tag="7"/>
                    </ComboBox>

                    <TextBlock Text="每日课程节数" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <NumberBox x:Name="PeriodCountBox"
                                Minimum="1"
                                Maximum="20"
                                ValueChanged="PeriodCountBox_ValueChanged"
                                Width="120"
                                HorizontalAlignment="Left"/>

                    <TextBlock Text="课程节次时间设置" Style="{StaticResource SettingsSectionLabelStyle}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Height="200"
                                  Width="240"
                                  Padding="0"
                                  HorizontalAlignment="Left">
                        <StackPanel x:Name="PeriodTimeInputsPanel"/>
                    </ScrollViewer>

                    <Button x:Name="ConfirmPeriodChangesButton"
                            Content="确认修改"
                            Margin="0,12,0,0"
                            IsEnabled="False"
                            Click="ConfirmPeriodChanges_Click"
                            Width="240"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>