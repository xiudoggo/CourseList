<Page
    x:Class="CourseList.Views.ToDoFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Language="zh-CN">

    <ScrollViewer>
        <Grid x:Name="FormRootGrid"
              Margin="20"
              RowSpacing="14"
              MaxWidth="900"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="FormTitleText"
                       Grid.Row="0"
                       Text="新增待办"
                       FontSize="30"
                       FontWeight="Bold"/>

            <TextBlock Grid.Row="1"
                       Text="完善任务信息后点击保存，支持后续继续编辑。"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Border Grid.Row="2"
                    CornerRadius="16"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="18" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="任务标题" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TitleTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             MaxWidth="620"
                             HorizontalAlignment="Stretch"
                             PlaceholderText="输入任务标题"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="任务内容" VerticalAlignment="Top" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBox x:Name="ContentTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             MinHeight="120"
                             MaxHeight="320"
                             MaxWidth="620"
                             HorizontalAlignment="Stretch"
                             TextWrapping="Wrap"
                             KeyDown="ContentTextBox_KeyDown"
                             PlaceholderText="输入任务详细内容"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="截止日期" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <DatePicker x:Name="DueDatePicker"
                                Grid.Row="2"
                                Grid.Column="1"
                                DayFormat="{}{day.integer}日"
                                MonthFormat="{}{month.integer}月"
                                YearVisible="False"
                                Language="zh-CN"
                                MaxWidth="320"
                                HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="优先级" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ComboBox x:Name="PriorityComboBox"
                              Grid.Row="3"
                              Grid.Column="1"
                              MaxWidth="320"
                              HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="标签" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="TagsTextBox"
                             Grid.Row="4"
                             Grid.Column="1"
                             MaxWidth="620"
                             HorizontalAlignment="Stretch"
                             PlaceholderText="例如：学习,考试,紧急"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="状态" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <CheckBox x:Name="CompletedCheckBox"
                              Grid.Row="5"
                              Grid.Column="1"
                              Content="标记为已完成"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="6"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8"
                                Margin="0,8,0,0">
                        <ProgressRing x:Name="SaveProgressRing"
                                      Width="20"
                                      Height="20"
                                      IsActive="False"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"/>
                        <Button Content="取消" Click="CancelBtn_Click"/>
                        <Button x:Name="SaveBtn"
                                Content="保存"
                                Click="SaveBtn_Click"
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
