<Page
    x:Class="CourseList.Views.ToDoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CourseList.Views"
    xmlns:models="using:CourseList.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:helpers="using:CourseList.Helpers"
    xmlns:uihelpers="using:CourseList.Helpers.Ui">

    <Page.Resources>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <uihelpers:TagNameToBrushConverter x:Key="TagNameToBrushConverter"/>
        <DataTemplate x:Key="ToDoCardTemplate" x:DataType="models:ToDoItem">
            <Grid Margin="6">
            <Border Height="168"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Opacity="0.92"
                    Visibility="{x:Bind IsDragPlaceholder, Mode=OneWay}"/>
            <Border Background="{ThemeResource CourseListCardBackgroundBrush}"
                    BorderBrush="{ThemeResource CourseListCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10"
                    Width="Auto"
                    MaxWidth="280"
                    HorizontalAlignment="Stretch"
                    Height="168"
                    Tag="{x:Bind}"
                    Translation="0,0,10"
                    RenderTransformOrigin="0.5,0.5"
                    Visibility="{x:Bind IsDragPlaceholder, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}"
                    PointerPressed="ToDoCard_PointerPressed"
                    PointerEntered="ToDoCard_PointerEntered"
                    PointerExited="ToDoCard_PointerExited">
                <Border.Shadow>
                    <media:ThemeShadow />
                </Border.Shadow>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0">
                        <CheckBox HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Content="完成"
                                  IsChecked="{x:Bind Completed, Mode=OneWay}"
                                  Checked="ToDoCompleted_Changed"
                                  Unchecked="ToDoCompleted_Changed"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <Button VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="2"
                                    MinWidth="26"
                                    MinHeight="26"
                                    Width="26"
                                    Height="26"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="置顶到小窗"
                                    Click="TodoCardPin_Click">
                                <Viewbox Width="14" Height="14"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <SymbolIcon Symbol="Pin"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Viewbox>
                            </Button>
                            <Border VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Padding="8,4"
                                    CornerRadius="6">
                                <Border.Background>
                                    <SolidColorBrush Color="{x:Bind PriorityEndColor, Mode=OneWay}"/>
                                </Border.Background>
                                <TextBlock Text="{x:Bind PriorityDisplayName, Mode=OneWay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,6,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Vertical" Spacing="4">
                            <TextBlock Text="{x:Bind Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind Content}"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="NoWrap"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <muxc:ItemsRepeater IsHitTestVisible="False"
                                                ItemsSource="{x:Bind Tags, Mode=OneWay}"
                                                HorizontalAlignment="Left">
                                <muxc:ItemsRepeater.Layout>
                                    <uihelpers:FlowWrapLayout HorizontalSpacing="6" VerticalSpacing="4"/>
                                </muxc:ItemsRepeater.Layout>
                                <muxc:ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border MinHeight="22"
                                                CornerRadius="11"
                                                Padding="8,3"
                                                HorizontalAlignment="Left"
                                                MaxWidth="280"
                                                Background="{x:Bind Converter={StaticResource TagNameToBrushConverter}, Mode=OneTime}"
                                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                ToolTipService.ToolTip="{x:Bind Mode=OneTime}">
                                            <TextBlock Text="{x:Bind Mode=OneTime}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFFFFFF"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="NoWrap"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </muxc:ItemsRepeater.ItemTemplate>
                            </muxc:ItemsRepeater>
                            <TextBlock Text="{x:Bind DueDateText}"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ToDoCardCompactTemplate" x:DataType="models:ToDoItem">
            <Grid Margin="6">
                <Border Height="128"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="12"
                        Opacity="0.92"
                        Visibility="{x:Bind IsDragPlaceholder, Mode=OneWay}"/>
                <Border Background="{ThemeResource CourseListCardBackgroundBrush}"
                        BorderBrush="{ThemeResource CourseListCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        HorizontalAlignment="Stretch"
                        Height="128"
                        Tag="{x:Bind}"
                        Translation="0,0,10"
                        RenderTransformOrigin="0.5,0.5"
                        Visibility="{x:Bind IsDragPlaceholder, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}"
                        PointerPressed="ToDoCard_PointerPressed"
                        PointerEntered="ToDoCard_PointerEntered"
                        PointerExited="ToDoCard_PointerExited">
                    <Border.Shadow>
                        <media:ThemeShadow />
                    </Border.Shadow>
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                            <TranslateTransform X="0" Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <CheckBox Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Content="完成"
                                  IsChecked="{x:Bind Completed, Mode=OneWay}"
                                  Checked="ToDoCompleted_Changed"
                                  Unchecked="ToDoCompleted_Changed"/>
                        <ScrollViewer Grid.Column="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Vertical"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind Title}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Content}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="NoWrap"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                                <muxc:ItemsRepeater IsHitTestVisible="False"
                                                    ItemsSource="{x:Bind Tags, Mode=OneWay}"
                                                    HorizontalAlignment="Left">
                                    <muxc:ItemsRepeater.Layout>
                                        <uihelpers:FlowWrapLayout HorizontalSpacing="6" VerticalSpacing="4"/>
                                    </muxc:ItemsRepeater.Layout>
                                    <muxc:ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border MinHeight="20"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    MaxWidth="220"
                                                    Background="{x:Bind Converter={StaticResource TagNameToBrushConverter}, Mode=OneTime}"
                                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    ToolTipService.ToolTip="{x:Bind Mode=OneTime}">
                                                <TextBlock Text="{x:Bind Mode=OneTime}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFFFF"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="NoWrap"
                                                           MaxLines="1"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </muxc:ItemsRepeater.ItemTemplate>
                                </muxc:ItemsRepeater>
                                <TextBlock Text="{x:Bind DueDateText}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="NoWrap"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </ScrollViewer>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <Button VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="2"
                                    MinWidth="26"
                                    MinHeight="26"
                                    Width="26"
                                    Height="26"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="置顶到小窗"
                                    Click="TodoCardPin_Click">
                                <Viewbox Width="14" Height="14"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <SymbolIcon Symbol="Pin"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Viewbox>
                            </Button>
                            <Border VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Padding="8,4"
                                    CornerRadius="6">
                                <Border.Background>
                                    <SolidColorBrush Color="{x:Bind PriorityEndColor, Mode=OneWay}"/>
                                </Border.Background>
                                <TextBlock Text="{x:Bind PriorityDisplayName, Mode=OneWay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="ToDoMainGrid" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,0" ColumnDefinitions="*,Auto,Auto,Auto">
            <TextBlock Grid.Column="0"
                       Text="📋 待办"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button x:Name="AddTodoBtn"
                    Grid.Column="1"
                    Content="➕ 新增"
                    Margin="8,0,0,0"
                    Click="AddTodoBtn_Click"/>
            <Button x:Name="EditTodoBtn"
                    Grid.Column="2"
                    Content="✏️ 编辑"
                    Margin="8,0,0,0"
                    Click="EditTodoBtn_Click"/>
            <Button x:Name="DeleteTodoBtn"
                    Grid.Column="3"
                    Content="🗑️ 删除"
                    Margin="8,0,0,0"
                    PointerEntered="DeleteTodoBtn_PointerEntered"
                    PointerExited="DeleteTodoBtn_PointerExited"
                    Click="DeleteTodoBtn_Click">
                <FlyoutBase.AttachedFlyout>
                    <Flyout x:Name="DeleteConfirmFlyout" Placement="Top">
                        <StackPanel Spacing="10" MinWidth="260">
                            <TextBlock x:Name="DeleteConfirmText"
                                       Text="确定要删除该待办吗？"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="取消" Click="DeleteConfirmCancel_Click"/>
                                <Button Content="删除"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Click="DeleteConfirmOk_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
            </Button>
        </Grid>

        <Grid x:Name="ToDoListHost"
              Grid.Row="1"
              PointerMoved="ToDoListHost_PointerMoved"
              PointerReleased="ToDoListHost_PointerReleased"
              PointerCaptureLost="ToDoListHost_PointerCaptureLost">
            <ScrollViewer x:Name="ToDoScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalContentAlignment="Stretch">
                <!-- 顶部留白：首行卡片 hover 上移 + 缩放时仍落在可绘区域内，避免上边框被 ScrollViewer 裁切 -->
                <Grid Padding="0,16,0,0">
                    <muxc:ItemsRepeater x:Name="ToDoRepeater"
                                        HorizontalAlignment="Stretch"
                                        ItemTemplate="{StaticResource ToDoCardTemplate}">
                        <muxc:ItemsRepeater.Layout>
                            <muxc:UniformGridLayout MinItemWidth="220"
                                                    MinItemHeight="180"
                                                    MinColumnSpacing="12"
                                                    MinRowSpacing="12"
                                                    ItemsStretch="Fill"/>
                        </muxc:ItemsRepeater.Layout>
                    </muxc:ItemsRepeater>
                </Grid>
            </ScrollViewer>
            <TextBlock x:Name="ToDoEmptyText"
                       Text="还没有待办，点击“新增”创建"
                       FontSize="15"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"
                       IsHitTestVisible="False"/>
            <Canvas x:Name="DragOverlay"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
        </Grid>

        <TeachingTip x:Name="TodoSelectionTeachingTip"
                     Title="提示"
                     PreferredPlacement="Bottom"
                     IsLightDismissEnabled="True"/>
    </Grid>
</Page>
