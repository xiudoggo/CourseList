<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CourseList.Views.TodoPinWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="待办置顶">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayoutGrid" Background="Transparent">
        <muxc:TabView x:Name="RootTabView"
                      VerticalAlignment="Stretch"
                      IsAddTabButtonVisible="False"
                      CanDragTabs="True"
                      CanReorderTabs="True"
                      CanTearOutTabs="False"
                      AllowDropTabs="True"
                      AllowDrop="True"
                      TabWidthMode="SizeToContent"
                      DoubleTapped="RootTabView_DoubleTapped"
                      PointerWheelChanged="RootTabView_PointerWheelChanged"
                      TabCloseRequested="RootTabView_TabCloseRequested"
                      TabDragStarting="RootTabView_TabDragStarting"
                      TabDragCompleted="RootTabView_TabDragCompleted"
                      TabStripDragOver="RootTabView_TabStripDragOver"
                      TabStripDrop="RootTabView_TabStripDrop"
                      TabDroppedOutside="RootTabView_TabDroppedOutside">
            <muxc:TabView.Resources>
                <Thickness x:Key="TabViewItemLeftScrollButtonContainerPadding">0</Thickness>
                <Thickness x:Key="TabViewItemRightScrollButtonContainerPadding">0</Thickness>
                <Style x:Key="TabViewScrollButtonStyle" TargetType="RepeatButton">
                    <Setter Property="Width" Value="0"/>
                    <Setter Property="Height" Value="0"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="IsHitTestVisible" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </muxc:TabView.Resources>
            <!-- 系统标题栏被隐藏后，需要一块可拖动区域；放在 TabStrip 下方（与你期望的位置一致） -->
            <muxc:TabView.TabStripFooter>
                <Grid x:Name="PinWindowDragRegion"
                      Height="28"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top"
                      IsHitTestVisible="True" />
            </muxc:TabView.TabStripFooter>
        </muxc:TabView>

        <!-- 底部拖拽条：左半宽，高度与顶部拖拽条一致（28） -->
        <Grid x:Name="BottomDragBarHost"
              VerticalAlignment="Bottom"
              HorizontalAlignment="Stretch"
              Height="28"
              Background="Transparent"
              IsHitTestVisible="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="BottomDragBar"
                    Grid.Column="0"
                    Background="#01000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <!-- 左下角三角握把：两条斜线（左上 -> 右下），短 + 长 -->
                <Canvas Width="28"
                        Height="28"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        IsHitTestVisible="False">
                    <shapes:Line X1="6" Y1="10" X2="22" Y2="26"
                                 Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                 StrokeThickness="2"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round"
                                 Opacity="0.85"/>
                    <shapes:Line X1="6" Y1="18" X2="14" Y2="26"
                                 Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                 StrokeThickness="2"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round"
                                 Opacity="0.85"/>
                </Canvas>
            </Border>
        </Grid>

        <Grid x:Name="SizingOverlay"
              Visibility="Collapsed"
              Background="{ThemeResource SystemControlAcrylicWindowBrush}">
            <Border HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Margin="16"
                    Padding="24"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid HorizontalAlignment="Stretch"
                      MaxWidth="520">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="拖拽窗口边缘调整后，点击固定大小保存。"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Stretch"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Row="1"
                               x:Name="SizingSizeText"
                               Text="当前尺寸: 500 x 500 DIP"
                               Margin="0,12,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Stretch"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="460"/>
                    <Button Grid.Row="2"
                            x:Name="SizingConfirmButton"
                            Content="固定大小"
                            HorizontalAlignment="Stretch"
                            Margin="0,12,0,0"
                            Click="SizingConfirmButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
